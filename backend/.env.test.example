# Collecta backend test environment.
# Copy this file to backend/.env.test for local test runs. Do not store real secrets here.

NODE_ENV=test
PORT=3001

DATABASE_URL=postgresql://collecta:collecta@localhost:5432/collecta_test?schema=public
DIRECT_URL=postgresql://collecta:collecta@localhost:5432/collecta_test?schema=public

API_KEY=test_api_key_12345678901234567890
JWT_SECRET=test_jwt_secret_123456789012345678901234567890
ADMIN_USER=admin
ADMIN_PASS=test-admin-password

ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=silent

# Optional provider integrations remain blank in local tests.
EVOLUTION_API_URL=
EVOLUTION_INSTANCE=collecta
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=test_evolution_webhook_secret_123456
PAYMENT_DETECTION_WEBHOOK_URL=
PAYMENT_DETECTION_WEBHOOK_TOKEN=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
