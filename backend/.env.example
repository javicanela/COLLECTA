# ============================================================
# Collecta V5 — Variables de Entorno (Backend)
# Copia este archivo como .env y llena los valores reales
# NUNCA subas el archivo .env al repositorio
# ============================================================

# Puerto del servidor Express
PORT=3001

# Entorno (production/development)
NODE_ENV=development

# ---- APIs de Inteligencia Artificial ----
# IMPORTANTE: Las API keys de IA se configuran SOLO en variables
# de entorno, NUNCA en la tabla Config de la base de datos.
# Gemini (Google) - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq - https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter - https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---- Autenticación ----
# API Key para autenticación de peticiones (para scripts/automación)
# Mínimo 32 caracteres, usa un generador aleatorio
API_KEY=genera_una_clave_aleatoria_larga_minimo_32_chars

# JWT Secret para tokens de sesión (mínimo 32 caracteres)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=genera_un_secreto_largo_y_aleatorio_aqui_minimo_32_chars

# Credenciales de administrador para login JWT
# ADMIN_USER puede ser un email o nombre de usuario
ADMIN_USER=admin
ADMIN_PASS=cambia_esta_contraseña_segura

# ---- Evolution API (WhatsApp programático) ----
# Documentación: https://doc.evolution-api.com
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE=collecta
EVOLUTION_API_KEY=your_evolution_api_key_here
EVOLUTION_WEBHOOK_SECRET=your_webhook_secret_here

# ---- Pipeline de detección de pagos (n8n webhook, opcional) ----
PAYMENT_DETECTION_WEBHOOK_URL=

# ---- CORS y Seguridad ----
# Orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,https://collecta-azure.vercel.app
