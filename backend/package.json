{
  "name": "backend",
  "version": "1.0.0",
  "description": "Collecta V5 Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec \"node --max-old-space-size=4096 -r ts-node/register src/index.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:test:push": "node --env-file-if-exists=.env.test ./node_modules/prisma/build/index.js db push --skip-generate",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:full": "node --env-file-if-exists=.env.test ./node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "test:smoke": "node --env-file-if-exists=.env.test ./node_modules/vitest/vitest.mjs run --config vitest.config.ts src/__tests__/phase8.smoke.test.ts",
    "test:integration": "node --env-file-if-exists=.env.test ./node_modules/vitest/vitest.mjs run --config vitest.config.ts src/__tests__",
    "test:whatsapp": "vitest run --config vitest.whatsapp.config.ts src/__tests__/whatsapp.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "6.4.1",
    "@supabase/supabase-js": "^2.101.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.14",
    "prisma": "6.4.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
