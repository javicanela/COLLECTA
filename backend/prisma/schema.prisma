generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  role      String   @default("asesor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id           String      @id @default(cuid())
  rfc          String      @unique
  nombre       String
  telefono     String?
  email        String?
  regimen      String?
  categoria    String?
  asesor       String?
  estado       String      @default("ACTIVO")
  notas        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  operations   Operation[]
  logEntries   LogEntry[]
}

model Operation {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tipo         String
  descripcion  String?
  monto        Float    @default(0)
  fechaVence   DateTime
  fechaPago    DateTime?
  estatus      String   @default("PENDIENTE")
  asesor       String?
  excluir      Boolean  @default(false)
  archived     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LogEntry {
  id           String   @id @default(cuid())
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tipo         String
  variante     String?
  resultado    String
  mensaje      String?
  telefono     String?
  modo         String   @default("PRUEBA")
  createdAt    DateTime @default(now())
}

model Config {
  key   String @id
  value String
}
