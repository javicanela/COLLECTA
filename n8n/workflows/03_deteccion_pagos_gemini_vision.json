        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"rfc\": \"{{ $json.rfc || '' }}\",\n  \"monto\": {{ $json.paymentData.monto }},\n  \"referencia\": \"{{ $json.paymentData.referencia || '' }}\",\n  \"fechaPago\": \"{{ $json.paymentData.fecha || '' }}\"\n}",
        "options": {
          "timeout": 10000
        }
      },
