          },
          "conditions": [
            {
              "id": "check-image",
              "leftValue": "={{ $json.body.image }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "isNotEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-has-image",
      "name": "🖼️ ¿Tiene imagen?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={{$env.GEMINI_API_KEY}}",
        "authentication": "none",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [{\n    \"parts\": [\n      {\n        \"text\": \"Analiza este comprobante de pago bancario mexicano. Extrae los siguientes datos en formato JSON estricto (sin markdown, solo JSON):\\n{\\n  \\\"monto\\\": número (sin signo de pesos),\\n  \\\"fecha\\\": \\\"YYYY-MM-DD\\\",\\n  \\\"referencia\\\": \\\"string\\\",\\n  \\\"banco_origen\\\": \\\"string\\\",\\n  \\\"banco_destino\\\": \\\"string\\\",\\n  \\\"beneficiario\\\": \\\"string\\\",\\n  \\\"concepto\\\": \\\"string\\\",\\n  \\\"clabe_destino\\\": \\\"string\\\"\\n}\\nSi no puedes extraer algún campo, pon null. Responde SOLO el JSON.\"\n      },\n      {\n        \"inline_data\": {\n          \"mime_type\": \"image/jpeg\",\n          \"data\": \"{{ $json.body.image }}\"\n        }\n      }\n    ]\n  }]\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "gemini-vision",
      "name": "🤖 Gemini Vision: Analizar",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [660, 200]
    },
    {
      "parameters": {
        "jsCode": "// Parse Gemini response to extract payment data\nconst geminiResponse = $input.first().json;\nlet text = '';\n\ntry {\n  text = geminiResponse.candidates[0].content.parts[0].text;\n} catch (e) {\n  return [{ json: { error: 'No se pudo leer la respuesta de Gemini', raw: geminiResponse } }];\n}\n\n// Clean the response - remove markdown code blocks if present\nlet cleaned = text.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n\ntry {\n  const parsed = JSON.parse(cleaned);\n  return [{ json: { \n    success: true, \n    paymentData: parsed,\n    rfc: $input.first().json.body?.rfc || null,\n    clientPhone: $input.first().json.body?.phone || null\n  }}];\n} catch (e) {\n  return [{ json: { \n    success: false, \n    error: 'No se pudo parsear JSON de Gemini', \n    rawText: text \n  }}];\n}\n"
      },
      "id": "parse-gemini",
      "name": "🔧 Parsear respuesta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-success",
              "leftValue": "={{ $json.success }}",
              "rightValue": "true",
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            },
            {
              "id": "check-monto",
              "leftValue": "={{ $json.paymentData.monto }}",
              "rightValue": "",
              "operator": {
                "type": "number",
                "operation": "isNotEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-parsed-ok",
      "name": "✅ ¿Datos extraídos?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1100, 200]
