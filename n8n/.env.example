# ========================================
# Collecta n8n Environment Variables
# ========================================
# Copy this file to your n8n instance environment
# or configure these in n8n Settings > Environment Variables

# ── Collecta API ──────────────────────────
# URL of your Collecta backend (without trailing slash)
# Local: http://localhost:3001
# Production: https://your-vps-ip:3001 or https://collecta-api.yourdomain.com
COLLECTA_API_URL=http://localhost:3001

# Same value as backend API_KEY. Do not commit real secrets.
API_KEY=your_collecta_backend_api_key_here

# ── Evolution API (WhatsApp) ──────────────
# Your Evolution API instance URL (without trailing slash)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE=collecta
EVOLUTION_API_KEY=your_evolution_api_key_here
EVOLUTION_WEBHOOK_SECRET=your_webhook_secret_here

# ── Gemini API (Vision for payment detection) ─
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram Bot (notifications) ──────────
# Create a bot via @BotFather on Telegram
# Get chat_id by messaging @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Gmail (optional, for email cobranza) ──
# Configure OAuth2 credentials in n8n UI
# Settings > Credentials > Gmail OAuth2
